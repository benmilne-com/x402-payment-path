{
  "name": "x402-payment-path",
  "version": "0.3.0",
  "description": "Gate any action behind x402 stablecoin payments. Agent-first, server-side, no client UI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "x402",
    "stablecoin",
    "payment",
    "agent",
    "USDC",
    "SBC",
    "micropayment",
    "402"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/benmilne-com/x402-payment-path"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@stablecoin.xyz/x402": "^0.4.1",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0",
    "viem": "^2.52.2"
  }
}
